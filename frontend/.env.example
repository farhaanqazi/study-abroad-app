# Backend API URL (FastAPI server)
VITE_API_URL=http://localhost:8000

# Clerk publishable key for the management console (/console).
# Get it from the Clerk Dashboard → API keys → React. Without it, the public
# vendor sites still work; the console shows a "not configured" notice.
# Prefer putting this in .env.local for local development.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Copy this file to .env (or .env.local) and fill in your values.
# .env / .env.local are gitignored — never commit credentials.
