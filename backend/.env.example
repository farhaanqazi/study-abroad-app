# ============================================================
# Chatbot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=Chatbot Starter
API_PREFIX=/api/v1
ENVIRONMENT=development

# ------------------------------------------------------------
# Database — any SQLAlchemy-supported async URL
# ------------------------------------------------------------
# Postgres example: postgresql+asyncpg://user:password@host:5432/dbname
# SQLite example  : sqlite+aiosqlite:///./local.db
# Run `alembic upgrade head` after first set-up to create the tables.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DATABASE_PASSWORD@localhost:5432/chatbot

# ------------------------------------------------------------
# Redis (required for conversation state + dedup)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=86400
SESSION_TTL_SECONDS=86400

# ------------------------------------------------------------
# Authentication (Clerk) — REQUIRED in production
# ------------------------------------------------------------
# Issuer + audience are validated on every bearer token (RS256/JWKS only).
# In production, ENVIRONMENT=production refuses to boot if these are unset.
# Derivable from your Clerk instance (Dashboard → API keys / JWT templates).
CLERK_ISSUER=https://YOUR-INSTANCE.clerk.accounts.dev
CLERK_AUDIENCE=
# CLERK_JWKS_URL=                 # defaults to {issuer}/.well-known/jwks.json
# CLERK_SECRET_KEY=               # Backend API calls only; NEVER sent to JWKS
# CLERK_JWKS_CACHE_TTL_SECONDS=3600

# ------------------------------------------------------------
# Platform back-office bootstrap (the FIRST super-admin)
# ------------------------------------------------------------
# Comma-separated Clerk user ids and/or emails auto-granted the `superadmin`
# platform role on login. This is the ONLY out-of-UI grant path; everyone else
# is promoted in the admin console by a superadmin. FAIL-CLOSED: leaving this
# empty grants nobody (never everybody). Example:
#   PLATFORM_SUPERADMINS=user_3EFf8eak57nqFohu6SDoJ2SGbV9,you@example.com
PLATFORM_SUPERADMINS=

# ------------------------------------------------------------
# LLM (Groq — get key at https://console.groq.com/keys)
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# CORS origins (comma-separated; use * only in development)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------
# Telegram
# ------------------------------------------------------------
# Bot tokens are stored per-tenant in the vendor_channels.provider_config
# JSONB column. This is just an optional default display name.
TELEGRAM_BOT_NAME=

# ------------------------------------------------------------
# WhatsApp Business API (optional — leave blank if unused)
# ------------------------------------------------------------
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ------------------------------------------------------------
# Webhook
# ------------------------------------------------------------
# Public URL Telegram/WhatsApp can reach. ngrok works for local dev.
WEBHOOK_BASE_URL=https://YOUR_PUBLIC_DOMAIN_OR_NGROK_URL
DEFAULT_TIMEZONE=Asia/Kolkata

# ------------------------------------------------------------
# Email (SMTP — for transactional mail; leave blank to disable)
# ------------------------------------------------------------
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
